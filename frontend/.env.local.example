# Copy to .env.local (not committed).

# Python AGUI URL — used by next.config.ts rewrites (browser calls same-origin /api/*).
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765

# Set to 1 to call AGUI directly from the browser (no Next proxy). You need working CORS on nanobot agui.
# NEXT_PUBLIC_AGUI_DIRECT=1

# If the browser origin is not in the list below, set on the AGUI side, e.g.:
# NANOBOT_AGUI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
